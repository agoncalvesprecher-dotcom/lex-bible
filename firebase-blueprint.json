{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "provider": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["email", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "cancelled", "expired", "trialing"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "trialUsed": { "type": "boolean" },
        "cancelAtPeriodEnd": { "type": "boolean" }
      },
      "required": ["userId", "planId", "status", "startDate", "endDate"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Available subscription plans",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "durationDays": { "type": "integer" },
        "features": { "type": "object" },
        "stripePriceId": { "type": "string" }
      },
      "required": ["name", "price", "durationDays"]
    },
    "PaymentProof": {
      "title": "PaymentProof",
      "description": "Proof of manual bank transfer",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "planId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "verified": { "type": "boolean" },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "amount": { "type": "number" },
        "reference": { "type": "string" }
      },
      "required": ["userId", "planId", "imageUrl", "createdAt"]
    },
    "UsageLimit": {
      "title": "UsageLimit",
      "description": "Daily usage limits for free users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "lexicalQueriesCount": { "type": "integer" }
      },
      "required": ["userId", "date", "lexicalQueriesCount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "User subscriptions"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "Subscription plans"
    },
    "/payment_proofs/{proofId}": {
      "schema": "PaymentProof",
      "description": "Manual payment proofs"
    },
    "/usage_limits/{limitId}": {
      "schema": "UsageLimit",
      "description": "Daily usage tracking"
    }
  }
}
